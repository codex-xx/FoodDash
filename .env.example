# Example environment variables for FoodDash
# Copy this file to `.env` locally and fill with real values.
# Do NOT commit real secrets into source control.

# App
CI_ENVIRONMENT=production
APP_BASE_URL=

# Database (choose DATABASE_URL OR individual DB_* vars)
# Example DATABASE_URL format: mysql://user:pass@host:3306/dbname
DATABASE_URL=
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=fooddash_db

# If your Aiven plan requires a CA certificate, you can set it here
# (not recommended to store multiline secrets in .env; prefer Render secret file)
AIVEN_CA_CERT=

# Email (SMTP)
EMAIL_FROM=noreply@fooddash.com
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_SMTP_CRYPTO=tls

# Optional
# REACT_APP_API_URL= (if you have a separate frontend)
