# CodeIgniter runtime artifacts (generated locally)
/writable/cache/*
/writable/debugbar/*
/writable/logs/*
/writable/session/*
/writable/uploads/*

# Keep placeholder files in each writable directory
!/writable/cache/index.html
!/writable/debugbar/index.html
!/writable/logs/index.html
!/writable/session/index.html
!/writable/uploads/index.html

# Composer dependencies (local build artifacts)
/vendor/